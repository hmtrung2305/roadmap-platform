{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "EmailVerification": {
    "OtpLength": 6,
    "ExpirationMinutes": 10,
    "ResendCooldownSeconds": 60,
    "MaxAttempts": 5
  },
  "SmtpEmail": {
    "Enabled": false,
    "Host": "smtp.gmail.com",
    "Port": 587,
    "UseStartTls": true,
    "FromName": "Roadmap Platform"
  },
  "Jwt": {
    "Issuer": "RoadmapPlatform",
    "Audience": "RoadmapPlatformUsers",
    "ExpirationMinutes": 60
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:3000"
    ]
  }
}
