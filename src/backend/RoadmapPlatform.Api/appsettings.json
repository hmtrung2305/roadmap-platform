{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "EmailVerification": {
    "OtpLength": 6,
    "ExpirationMinutes": 10,
    "ResendCooldownSeconds": 60,
    "MaxAttempts": 5
  },
  "SmtpEmail": {
    "Enabled": true,
    "Host": "smtp.gmail.com",
    "Port": 587,
    "UseStartTls": true,
    "FromName": "Roadmap Platform"
  },
  "Captcha": {
    "Enabled": false,
    "Provider": "Turnstile",
    "SiteKey": "",
    "SecretKey": "",
    "VerifyUrl": "https://challenges.cloudflare.com/turnstile/v0/siteverify"
  },
  "Jwt": {
    "Issuer": "RoadmapPlatform",
    "Audience": "RoadmapPlatformUsers",
    "ExpirationMinutes": 60
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:3000"
    ]
  },
  "Ai": {
    "Provider": "Gemini",
    "ApiKey": "",
    "Model": "gemini-2.5-flash",
    "EmbeddingModel": "gemini-embedding-2"
  },
  "Rag": {
    "MaxChunks": 3,
    "SimilarityThreshold": 0.6
  },
  "FileStorage": {
    "Provider": "Local",
    "LocalFolder": "docs"
  },
  "SupabaseStorage": {
    "Url": "",
    "ServiceRoleKey": "",
    "Bucket": "roadmap-docs"
  }
}
